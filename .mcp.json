{
  "mcpServers": {
    "safe-proxy": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "safe_mcp_proxy.mcp_server"],
      "cwd": "."
    },
    "safe-proxy-read-only": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "safe_mcp_proxy.mcp_server", "--world", "read_only"],
      "cwd": "."
    }
  }
}
